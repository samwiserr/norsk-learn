# === Required ===

# Google Gemini API key (server-side, used for AI tutoring)
GEMINI_API_KEY=

# Public site URL (no trailing slash). Used for trusted redirects (e.g. Stripe checkout).
# On Vercel, VERCEL_URL is used automatically if this is unset.
NEXT_PUBLIC_SITE_URL=

# === Firebase (required for auth & sync) ===

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === Optional: OpenAI Realtime (voice tutoring) ===

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# === Optional: Azure Speech (pronunciation assessment) ===

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# === Optional: Pronunciation service URL ===

PRONUNCIATION_SERVICE_URL=http://127.0.0.1:8000

# === Optional: Firebase Admin (server-side token verification) ===
# Enable authenticated users to persist server-owned session snapshots by user scope.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# === Optional: Sentry (error tracking) ===

NEXT_PUBLIC_SENTRY_DSN=

# === Optional: Rate Limiting ===

RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# === Optional: Upstash Redis (production rate limiting) ===

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
