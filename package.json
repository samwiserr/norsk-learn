{
  "name": "norsk-tutor",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "jest",
    "test:gate": "jest --forceExit --runTestsByPath __tests__/contracts/apiSchemas.test.ts __tests__/contracts/sessionSync.test.ts __tests__/lib/api/publicRoute.test.ts __tests__/server/conversationTurnUseCase.test.ts app/api/openai-realtime/route.test.ts app/api/azure-speech-token/route.test.ts app/api/sessions/sync/route.test.ts tests/evals/tutor-runtime.test.ts",
    "test:backend-qa": "jest --forceExit --config jest.backend-qa.config.js --runTestsByPath __tests__/contracts/apiSchemas.test.ts __tests__/contracts/sessionSync.test.ts __tests__/lib/api/publicRoute.test.ts __tests__/lib/contracts/conversation.contract.test.ts __tests__/server/conversationTurnUseCase.test.ts __tests__/backend-qa/apiService.sendMessageStreaming.test.ts app/api/openai-realtime/route.test.ts app/api/azure-speech-token/route.test.ts app/api/sessions/sync/route.test.ts tests/evals/tutor-runtime.test.ts --coverage",
    "test:e2e": "playwright test",
    "test:frontend-gate": "npm run lint && npm run test:e2e -- e2e/shell-routes.spec.ts e2e/onboarding.spec.ts e2e/writing-flow.spec.ts e2e/api-failure-path.spec.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "review:analyze": "node scripts/code-review/analyze-pr.mjs --output review-report.json",
    "review:report": "node scripts/code-review/render-report.mjs --input review-report.json --output review-report.md",
    "review:ci": "npm run review:analyze && npm run review:report"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.1",
    "@sentry/nextjs": "^10.32.1",
    "@stripe/stripe-js": "^8.6.1",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.562.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.47.0",
    "next": "^15.5.14",
    "posthog-js": "^1.310.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "server-only": "^0.0.1",
    "stripe": "^20.1.2",
    "tailwind-merge": "^3.4.0",
    "validator": "^13.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "20.11.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.11.0",
    "autoprefixer": "^10.4.23",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.14",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "5.5.4"
  }
}
